# =============================================================
# Aperix Admin — Environment Variables (TEMPLATE)
# =============================================================
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local` (already in .gitignore).
#
# In Netlify production, set the same variables under
# Site settings → Environment variables.
#
# A blank value means the feature degrades gracefully:
#   - Live data adapter falls back to Empty mode
#   - GitHub / Netlify / Render panels show "not connected"
#   - SSL/domain refresh is skipped
#   - Email digest is skipped
# =============================================================


# -------------------------------------------------------------
# Track 1 — Supabase (database + auth)
# -------------------------------------------------------------
# From Supabase dashboard → Project Settings → API.
# SERVICE_ROLE_KEY MUST stay server-side. Never log it.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local dev only — for `supabase` CLI when running migrations.
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=


# -------------------------------------------------------------
# Track 2 — Auth allowlist
# -------------------------------------------------------------
# Comma-separated emails allowed to sign in. Last line of
# defence behind Cloudflare Access.
ADMIN_ALLOWED_EMAILS=


# -------------------------------------------------------------
# Track 3 — GitHub
# -------------------------------------------------------------
# Fine-grained PAT, scoped to AperixStudio org.
# Permissions: Contents:Read, Metadata:Read.
GITHUB_TOKEN=
GITHUB_ORG=AperixStudio


# -------------------------------------------------------------
# Track 4 — Hosting providers
# -------------------------------------------------------------
# Netlify: User settings → Applications → Personal access tokens.
NETLIFY_TOKEN=

# Render: Account settings → API keys (read-only is enough).
RENDER_API_KEY=


# -------------------------------------------------------------
# Track 5 — Domains / DNS / SSL
# -------------------------------------------------------------
# Cloudflare API token (Zone:Read, DNS:Read, SSL:Read).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=


# -------------------------------------------------------------
# Track 6 — Email (Resend)
# -------------------------------------------------------------
RESEND_API_KEY=

# From-address must be on a verified Resend domain.
ADMIN_EMAIL_FROM=hello@aperix.com.au

# Falls back to ADMIN_ALLOWED_EMAILS if blank.
ADMIN_EMAIL_DIGEST_TO=


# -------------------------------------------------------------
# Track 7 — AI Query (deferred — feature flag off by default)
# -------------------------------------------------------------
GROQ_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434


# -------------------------------------------------------------
# Track 9 — Cron / scheduled jobs
# -------------------------------------------------------------
# Shared secret protecting /api/cron/* routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=


# -------------------------------------------------------------
# Track 10 — App-wide
# -------------------------------------------------------------
# Canonical URL of this admin app. Used in email links and
# magic-link redirects. Set per environment:
#   Local dev:   http://localhost:3000
#   Netlify:     https://<your-site>.netlify.app
#   Production:  https://admin.aperixstudio.com.au
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — force data mode on server start (otherwise cookie controls it).
# DEFAULT_DATA_MODE=live
